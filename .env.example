# Sandbox token (from PRAL sandbox registration)
FBR_SANDBOX_TOKEN=your_sandbox_token_here
# Production token (from PRAL production registration)
FBR_PRODUCTION_TOKEN=your_production_token_here
# Legacy fallback (used if above are not set)
FBR_BEARER_TOKEN=your_token_here

# "sandbox" or "production"
FBR_ENV=sandbox

# Set to "true" to skip real FBR API calls (testing only — restart server after changes)
FBR_MOCK_MODE=false

# Mock: simulate network failure on every attempt (triggers auto-retry queue)
# FBR_MOCK_FAIL=true

# Mock: fail only until retry_count reaches N, then succeed (e.g. 2 = fail twice, succeed on 3rd)
# FBR_MOCK_FAIL_UNTIL_RETRY=2

# Mock: delay each FBR call by N ms (watch queued → processing in History)
# FBR_MOCK_DELAY_MS=5000

# Mock response scenario: valid | invalid | edited | cancelled | partial_edit | partial_cancel | partial_both | http_500
# FBR_MOCK_SCENARIO=partial_edit

# Worker poll interval in ms (default 3000)
# WORKER_POLL_MS=3000
# WORKER_ENABLED=true

# Port for the local web server
PORT=3000

# "planetive" = SN019 services-only workflow; "full" = all FBR scenarios
APP_MODE=planetive

# Temporary: verbose FBR validate logging to Railway console (revert after sandbox debugging)
# FBR_DEBUG_VALIDATE=true

# Supabase (server-side only — use service role key, never expose to browser)
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your_service_role_key_here

# Railway: Service → Variables — add all variables above (copy from your local .env).
# Vercel: Project → Settings → Environment Variables.
# On Railway/Render the queue worker runs by default (WORKER_ENABLED=true).
# On Vercel serverless, set WORKER_ENABLED=false or deploy the worker on Railway instead.
